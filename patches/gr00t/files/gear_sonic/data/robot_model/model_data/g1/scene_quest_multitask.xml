<mujoco model="g1_quest_multitask_lab">
  <!-- GR00T locomanip 风格宽台面：多物体 PnP / 抓取 / 收纳 / 行走 -->
  <size memory="64M" nconmax="256"/>

  <include file="g1_29dof_with_hand.xml"/>

  <statistic center="0.45 0 0.88" extent="2.0"/>

  <visual>
    <headlight diffuse="0.62 0.62 0.62" ambient="0.32 0.32 0.32" specular="0 0 0"/>
    <rgba haze="0.14 0.22 0.32 1"/>
    <global azimuth="-125" elevation="-18"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.32 0.48 0.68" rgb2="0.06 0.08 0.12" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.24 0.30 0.38" rgb2="0.14 0.18 0.24"
      markrgb="0.7 0.7 0.7" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.12"/>
    <texture type="2d" name="table_tex" builtin="flat" rgb1="0.68 0.58 0.46" width="512" height="512"/>
    <material name="table_mat" texture="table_tex" texuniform="true" reflectance="0.1"/>
    <material name="wall_mat" rgba="0.38 0.40 0.44 1" reflectance="0.04"/>
    <material name="backsplash_mat" rgba="0.48 0.50 0.54 1" reflectance="0.06"/>
    <material name="plate_mat" rgba="0.93 0.93 0.98 1" reflectance="0.28"/>
    <material name="faucet_mat" rgba="0.76 0.80 0.86 1" reflectance="0.4"/>
    <material name="apple_mat" rgba="0.90 0.16 0.10 1" reflectance="0.22"/>
    <material name="cube_mat" rgba="0.18 0.58 0.95 1" reflectance="0.18"/>
    <material name="bottle_mat" rgba="0.22 0.72 0.38 1" reflectance="0.2"/>
    <material name="bin_blue_mat" rgba="0.20 0.42 0.88 0.85" reflectance="0.08"/>
    <material name="bin_green_mat" rgba="0.22 0.68 0.32 0.85" reflectance="0.08"/>
    <material name="cone_mat" rgba="1.0 0.78 0.12 1" reflectance="0.1"/>
    <material name="shelf_mat" rgba="0.52 0.46 0.40 1" reflectance="0.06"/>
  </asset>

  <worldbody>
    <light pos="0.3 0 2.4" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Lab backdrop -->
    <geom name="wall_back" type="box" pos="0.88 0 1.05" size="0.04 0.62 0.55" material="wall_mat"/>
    <geom name="backsplash" type="box" pos="0.72 0 0.98" size="0.02 0.58 0.22" material="backsplash_mat"/>

    <!-- Wide workbench: ~1.1m (y) × 44cm (x) -->
    <body name="table_body" pos="0.50 0 0.46">
      <geom name="table_top" pos="0 0 0.30" size="0.22 0.55 0.04" type="box" material="table_mat"/>
      <geom name="table_leg1" pos="0.0 0.50 -0.14" size="0.12 0.03 0.18" type="box" material="table_mat"/>
      <geom name="table_leg2" pos="0.0 -0.50 -0.14" size="0.12 0.03 0.18" type="box" material="table_mat"/>
    </body>

    <!-- Back shelf (visual anchor, GR00T lab feel) -->
    <body name="shelf_body" pos="0.78 0 1.12">
      <geom name="shelf_board" type="box" size="0.18 0.28 0.015" material="shelf_mat"/>
    </body>

    <!-- Faucet above sink area -->
    <body name="faucet_body" pos="0.64 0.0 0.94">
      <geom name="faucet_base" type="cylinder" size="0.024 0.03" material="faucet_mat"/>
      <geom name="faucet_spout" type="capsule" fromto="0 0 0.03  -0.11 0 0.01" size="0.011" material="faucet_mat"/>
    </body>

    <!-- Left: plate + red cylinder (GR00T PnP apple→plate) -->
    <body name="plate_body" pos="0.36 0.32 0.812">
      <geom name="plate" type="cylinder" size="0.06 0.009" material="plate_mat"/>
    </body>

    <body name="apple_body" pos="0.34 0.14 0.84">
      <joint type="free" damping="0.02" name="apple_joint"/>
      <geom name="apple" type="cylinder" size="0.022 0.04" material="apple_mat"
        solimp="0.92 0.98 0.001" solref="0.05 1" density="45" friction="0.85 0.2 0.05"
        margin="0.002"/>
    </body>

    <!-- Center: green bottle (grasp & lift) -->
    <body name="bottle_body" pos="0.40 0.0 0.858">
      <joint type="free" damping="0.02" name="bottle_joint"/>
      <geom name="bottle" type="cylinder" size="0.026 0.065" material="bottle_mat"
        solimp="0.92 0.98 0.001" solref="0.05 1" density="40" friction="0.85 0.2 0.05"
        margin="0.002"/>
    </body>

    <!-- Right: blue cube -->
    <body name="cube_body" pos="0.34 -0.22 0.828">
      <joint type="free" damping="0.015" name="cube_joint"/>
      <geom name="cube" size="0.028 0.028 0.028" type="box" material="cube_mat"
        solimp="0.92 0.98 0.001" solref="0.05 1" density="50" friction="0.85 0.2 0.05"
        margin="0.002"/>
    </body>

    <!-- Sort bins on table edges -->
    <body name="bin_green_body" pos="0.52 0.40 0.808">
      <geom name="bin_green_floor" type="box" pos="0 0 0.004" size="0.055 0.055 0.004" material="bin_green_mat"/>
      <geom name="bin_green_wall_x" type="box" pos="0.055 0 0.028" size="0.004 0.055 0.028" material="bin_green_mat"/>
      <geom name="bin_green_wall_y" type="box" pos="0 0.055 0.028" size="0.055 0.004 0.028" material="bin_green_mat"/>
    </body>

    <body name="bin_blue_body" pos="0.52 -0.40 0.808">
      <geom name="bin_blue_floor" type="box" pos="0 0 0.004" size="0.055 0.055 0.004" material="bin_blue_mat"/>
      <geom name="bin_blue_wall_x" type="box" pos="0.055 0 0.028" size="0.004 0.055 0.028" material="bin_blue_mat"/>
      <geom name="bin_blue_wall_y" type="box" pos="0 -0.055 0.028" size="0.055 0.004 0.028" material="bin_blue_mat"/>
    </body>

    <!-- Navigation markers -->
    <geom name="cone_a" type="cylinder" pos="0.58 0.22 0.12" size="0.06 0.12" material="cone_mat"/>
    <geom name="cone_b" type="cylinder" pos="0.58 -0.22 0.12" size="0.06 0.12" material="cone_mat"/>
    <site name="walk_goal" pos="0.58 0.0 0.015" size="0.16" rgba="0.15 0.88 0.35 0.55" type="cylinder"/>

    <site name="com_marker" pos="0.05 0 0" size="0.04" rgba="1 0 0 0.6" type="sphere"/>
  </worldbody>

  <default>
    <geom friction="0.85 0.2 0.05"/>
  </default>

  <contact>
    <exclude body1="left_wrist_yaw_link" body2="left_hand_thumb_0_link"/>
    <exclude body1="left_hand_thumb_0_link" body2="left_hand_thumb_1_link"/>
    <exclude body1="left_hand_thumb_1_link" body2="left_hand_thumb_2_link"/>
    <exclude body1="left_wrist_yaw_link" body2="left_hand_index_0_link"/>
    <exclude body1="left_hand_index_0_link" body2="left_hand_index_1_link"/>
    <exclude body1="left_wrist_yaw_link" body2="left_hand_middle_0_link"/>
    <exclude body1="left_hand_middle_0_link" body2="left_hand_middle_1_link"/>
    <exclude body1="right_wrist_yaw_link" body2="right_hand_thumb_0_link"/>
    <exclude body1="right_hand_thumb_0_link" body2="right_hand_thumb_1_link"/>
    <exclude body1="right_hand_thumb_1_link" body2="right_hand_thumb_2_link"/>
    <exclude body1="right_wrist_yaw_link" body2="right_hand_index_0_link"/>
    <exclude body1="right_hand_index_0_link" body2="right_hand_index_1_link"/>
    <exclude body1="right_wrist_yaw_link" body2="right_hand_middle_0_link"/>
    <exclude body1="right_hand_middle_0_link" body2="right_hand_middle_1_link"/>
  </contact>
</mujoco>
