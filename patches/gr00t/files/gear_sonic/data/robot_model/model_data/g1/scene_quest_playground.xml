<mujoco model="g1_quest_teleop_counter">
  <!-- Wide counter; props spaced apart; tabletop z ≈ 0.80m -->
  <!-- G1+hands+抓取: 默认 ~16M 不够 → stack overflow / segfault (MuJoCo 3.9 用 memory，勿用 nstack) -->
  <size memory="64M" nconmax="256"/>

  <include file="g1_29dof_with_hand.xml"/>

  <statistic center="0.38 0 0.88" extent="1.8"/>

  <visual>
    <headlight diffuse="0.65 0.65 0.65" ambient="0.35 0.35 0.35" specular="0 0 0"/>
    <rgba haze="0.12 0.22 0.32 1"/>
    <global azimuth="-120" elevation="-18"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.35 0.55 0.75" rgb2="0.08 0.1 0.14" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.22 0.32 0.42" rgb2="0.12 0.18 0.26"
      markrgb="0.75 0.75 0.75" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="4 4" reflectance="0.15"/>
    <texture type="2d" name="counter_tex" builtin="flat" rgb1="0.72 0.64 0.54" width="512" height="512"/>
    <material name="counter_mat" texture="counter_tex" texuniform="true" reflectance="0.12"/>
    <material name="backsplash_mat" rgba="0.42 0.44 0.48 1" reflectance="0.05"/>
    <material name="sink_mat" rgba="0.55 0.58 0.62 1" reflectance="0.25"/>
    <material name="plate_mat" rgba="0.92 0.92 0.97 1" reflectance="0.3"/>
    <material name="faucet_mat" rgba="0.78 0.82 0.88 1" reflectance="0.45"/>
    <texture type="2d" name="cube_tex" builtin="flat" rgb1="0.2 0.62 0.92" width="512" height="512"/>
    <material name="cube_mat" texture="cube_tex" texuniform="true" reflectance="0.2"/>
    <material name="apple_mat" rgba="0.88 0.18 0.12 1" reflectance="0.25"/>
    <material name="cone_mat" rgba="1.0 0.78 0.1 1" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light pos="0.2 0 2.2" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <geom name="backsplash" type="box" pos="0.52 0 1.02" size="0.03 0.48 0.30" material="backsplash_mat"/>

    <!-- Wide counter: 84cm (y) × 36cm (x depth) -->
    <body name="table_body" pos="0.36 0 0.48">
      <geom name="table_top" pos="0 0 0.28" size="0.18 0.42 0.04" type="box" material="counter_mat"/>
      <geom name="table_leg1" pos="0.0 0.38 -0.16" size="0.14 0.03 0.20" type="box" material="counter_mat"/>
      <geom name="table_leg2" pos="0.0 -0.38 -0.16" size="0.14 0.03 0.20" type="box" material="counter_mat"/>
      <geom name="sink_basin" type="box" pos="0.12 0 0.30" size="0.12 0.16 0.06" material="sink_mat"/>
    </body>

    <!-- Back center: faucet + sink -->
    <body name="faucet_body" pos="0.48 0 0.92">
      <geom name="faucet_base" type="cylinder" size="0.022 0.028" material="faucet_mat"/>
      <geom name="faucet_spout" type="capsule" fromto="0 0 0.028  -0.10 0 0.01" size="0.01" material="faucet_mat"/>
    </body>

    <!-- Left: plate -->
    <body name="plate_body" pos="0.30 0.26 0.812">
      <geom name="plate" type="cylinder" size="0.055 0.008" material="plate_mat"/>
    </body>

    <!-- Center-left: red cylinder (easier to grasp than sphere) -->
    <body name="apple_body" pos="0.28 0.04 0.84">
      <joint type="free" damping="0.02" name="apple_joint"/>
      <geom name="apple" type="cylinder" size="0.022 0.04" material="apple_mat"
        solimp="0.92 0.98 0.001" solref="0.05 1" density="45" friction="0.85 0.2 0.05"
        margin="0.002"/>
    </body>

    <!-- Right: cube (right hand) -->
    <body name="cube_body" pos="0.26 -0.24 0.828">
      <joint type="free" damping="0.015" name="cube_joint"/>
      <geom name="cube" size="0.028 0.028 0.028" type="box" material="cube_mat"
        solimp="0.92 0.98 0.001" solref="0.05 1" density="50" friction="0.85 0.2 0.05"
        margin="0.002"/>
    </body>

    <geom name="cone_a" type="cylinder" pos="0.46 0.20 0.12" size="0.06 0.12" material="cone_mat"/>
    <geom name="cone_b" type="cylinder" pos="0.46 -0.20 0.12" size="0.06 0.12" material="cone_mat"/>
    <site name="walk_goal" pos="0.48 0.0 0.015" size="0.14" rgba="0.15 0.88 0.35 0.55" type="cylinder"/>

    <site name="com_marker" pos="0.05 0 0" size="0.04" rgba="1 0 0 0.6" type="sphere"/>
  </worldbody>

  <default>
    <geom friction="0.85 0.2 0.05"/>
  </default>

  <contact>
    <!-- Same-hand finger links: skip adjacent self-collisions (grasp stability) -->
    <exclude body1="left_wrist_yaw_link" body2="left_hand_thumb_0_link"/>
    <exclude body1="left_hand_thumb_0_link" body2="left_hand_thumb_1_link"/>
    <exclude body1="left_hand_thumb_1_link" body2="left_hand_thumb_2_link"/>
    <exclude body1="left_wrist_yaw_link" body2="left_hand_index_0_link"/>
    <exclude body1="left_hand_index_0_link" body2="left_hand_index_1_link"/>
    <exclude body1="left_wrist_yaw_link" body2="left_hand_middle_0_link"/>
    <exclude body1="left_hand_middle_0_link" body2="left_hand_middle_1_link"/>
    <exclude body1="right_wrist_yaw_link" body2="right_hand_thumb_0_link"/>
    <exclude body1="right_hand_thumb_0_link" body2="right_hand_thumb_1_link"/>
    <exclude body1="right_hand_thumb_1_link" body2="right_hand_thumb_2_link"/>
    <exclude body1="right_wrist_yaw_link" body2="right_hand_index_0_link"/>
    <exclude body1="right_hand_index_0_link" body2="right_hand_index_1_link"/>
    <exclude body1="right_wrist_yaw_link" body2="right_hand_middle_0_link"/>
    <exclude body1="right_hand_middle_0_link" body2="right_hand_middle_1_link"/>
  </contact>
</mujoco>
